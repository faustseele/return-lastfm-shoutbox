{
  "name": "return-lastfm-shoutbox",
  "description": "Brings back inline shouts on Last.fm pages",
  "version": "0.0.0",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "postinstall": "wxt prepare",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "vitest run --passWithNoTests",
    "icons:generate": "tsx scripts/resize-icons.ts",
    "publish:chrome": "chrome-webstore-upload upload --source \"$(ls .output/*-chrome.zip)\" --auto-publish",
    "publish:firefox": "web-ext sign --source-dir .output/firefox-mv2 --channel listed --api-key $AMO_API_KEY --api-secret $AMO_API_SECRET"
  },
  "dependencies": {
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/jsdom": "^28.0.1",
    "chrome-webstore-upload-cli": "^3.5.0",
    "jsdom": "^29.0.2",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4",
    "web-ext": "^10.1.0",
    "wxt": "latest"
  }
}
